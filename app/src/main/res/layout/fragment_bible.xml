<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Premium Glow Header Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_lobby_header"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ĐỌC KINH THÁNH"
            android:textColor="@color/gold_gold"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="2"
            android:shadowRadius="2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/layout_coins" />

        <TextView
            android:id="@+id/tv_header_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Linh hồn tôi khát khao Thiên Chúa hằng sống"
            android:textColor="@color/white"
            android:alpha="0.85"
            android:textSize="14sp"
            android:textStyle="italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_header_title"
            app:layout_constraintEnd_toStartOf="@id/layout_coins" />

        <!-- Gamification Coins Badge -->
        <LinearLayout
            android:id="@+id/layout_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_coins_badge"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_user_coins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Floating Capsule TabLayout for Cựu Ước / Tân Ước -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header_text">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="@color/gold_gold"
            app:tabSelectedTextColor="@color/primary_blue"
            app:tabTextColor="@color/text_muted"
            app:tabIndicatorGravity="bottom"
            app:tabIndicatorHeight="3dp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Books RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_books"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_tab" />

</androidx.constraintlayout.widget.ConstraintLayout>
