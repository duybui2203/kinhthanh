<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Abbreviation Indicator Bubble with gold outline -->
        <View
            android:id="@+id/bg_abbrev"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_abbrev_bubble"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_abbrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="St"
            android:textColor="@color/gold_gold"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/bg_abbrev"
            app:layout_constraintEnd_toEndOf="@id/bg_abbrev"
            app:layout_constraintStart_toStartOf="@id/bg_abbrev"
            app:layout_constraintTop_toTopOf="@id/bg_abbrev" />

        <!-- Book Names (Vietnamese main, English sub) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_book_reward"
            app:layout_constraintStart_toEndOf="@id/bg_abbrev"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_book_name_vi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sáng Thế"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_book_name_en"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Genesis"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Reward Text -->
        <TextView
            android:id="@+id/tv_book_reward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="+500 🪙"
            android:textColor="#C9A054"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_arrow"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Gold Chevron Arrow -->
        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/gold_gold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Open chapters" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
