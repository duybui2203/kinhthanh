<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/reader_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_blue"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@color/gold_gold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Navigation Bar -->
    <LinearLayout
        android:id="@+id/layout_header_nav"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/background_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/reader_toolbar">

        <ImageButton
            android:id="@+id/btn_header_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev"
            app:tint="@color/primary_blue"
            android:contentDescription="Previous Chapter" />

        <TextView
            android:id="@+id/tv_header_chapter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Chương 1"
            android:textColor="@color/primary_blue"
            android:textSize="17sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <ImageButton
            android:id="@+id/btn_header_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next"
            app:tint="@color/primary_blue"
            android:contentDescription="Next Chapter" />

    </LinearLayout>

    <!-- Main Content ScrollView -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/card_media_player"
        app:layout_constraintTop_toBottomOf="@id/layout_header_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card wrapper for text content to make it look premium -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">



                    <!-- Continuous Vietnamese Text -->
                    <TextView
                        android:id="@+id/tv_verses_content_vi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang tải văn bản..."
                        android:textColor="@color/text_dark"
                        android:textSize="18sp"
                        android:lineSpacingExtra="6dp"
                        android:textIsSelectable="true" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quiz Button at the end of the book -->
            <Button
                android:id="@+id/btn_take_quiz"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/gold_gold"
                android:text="LÀM BÀI KIỂM TRA ĐỂ NHẬN THƯỞNG 🪙"
                android:textColor="@color/primary_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Loading / Progress Container -->
    <LinearLayout
        android:id="@+id/layout_download"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/background_light"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/card_media_player"
        app:layout_constraintTop_toBottomOf="@id/layout_header_nav">

        <ProgressBar
            android:id="@+id/progress_download"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="@color/gold_gold" />

        <TextView
            android:id="@+id/tv_download_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Đang tải Lời Chúa..."
            android:textColor="@color/text_muted"
            android:textSize="16sp"
            android:textStyle="italic" />

    </LinearLayout>

    <!-- Media Player Control Panel Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_media_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/primary_blue"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp">

            <!-- SeekBar and Progress Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_media_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Câu 1"
                    android:textColor="@color/gold_light"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekbar_media"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxHeight="4dp"
                    android:minHeight="4dp"
                    android:progressDrawable="@drawable/progress_bar_gold"
                    android:thumbTint="@color/gold_gold" />

                <TextView
                    android:id="@+id/tv_media_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 câu"
                    android:textColor="@color/gold_light"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Buttons Controls -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Play / Pause Center -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btn_tts_play"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:fabSize="normal"
                    android:src="@drawable/ic_play"
                    app:tint="@color/primary_blue"
                    app:backgroundTint="@color/gold_gold"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MaterialComponents.FloatingActionButton"
                    android:contentDescription="Play Audio"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Rewind (left of play) -->
                <ImageButton
                    android:id="@+id/btn_media_rewind"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_rewind"
                    app:tint="@color/gold_gold"
                    android:contentDescription="Rewind 1 verse"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_tts_play"
                    android:layout_marginEnd="16dp" />

                <!-- Prev Chapter (left edge) -->
                <ImageButton
                    android:id="@+id/btn_footer_prev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_prev"
                    app:tint="@color/gold_light"
                    android:contentDescription="Previous Chapter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Forward (right of play) -->
                <ImageButton
                    android:id="@+id/btn_media_forward"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_forward"
                    app:tint="@color/gold_gold"
                    android:contentDescription="Forward 1 verse"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_tts_play"
                    android:layout_marginStart="16dp" />

                <!-- Speed Control Button (right of Forward) -->
                <TextView
                    android:id="@+id/btn_tts_speed"
                    android:layout_width="44dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="1.0x"
                    android:textColor="@color/gold_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_media_forward"
                    android:layout_marginStart="8dp" />

                <!-- Next Chapter (right edge) -->
                <ImageButton
                    android:id="@+id/btn_footer_next"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_next"
                    app:tint="@color/gold_light"
                    android:contentDescription="Next Chapter"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
